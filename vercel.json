{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "server.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.py"
    }
  ],
  "functions": {
    "server.py": {
      "excludeFiles": "{vendor/**,downloads/**,public/**/*.pdf,public/**/*.docx,**/*.pdf,**/*.docx}"
    }
  }
}
